NONAV_API_LISTEN_ADDR=:8081
NONAV_DB_PATH=./data/nonav.db
NONAV_CORS_ORIGIN=http://127.0.0.1:5173
NONAV_PUBLIC_BASE_URL=http://lvh.me:8080
NONAV_SHARE_SUBDOMAIN_ENABLED=true
