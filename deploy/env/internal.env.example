NONAV_API_LISTEN_ADDR=:8081
NONAV_DB_PATH=/opt/nonav/data/nonav.db
NONAV_CORS_ORIGIN=https://node.sourcedream.cn
NONAV_PUBLIC_BASE_URL=https://node.sourcedream.cn

# Force all shares through FRP
NONAV_FORCE_FRP=true
NONAV_FRP_UPSTREAM_URL=http://127.0.0.1:13000
NONAV_FRP_PORT_MIN=13000
NONAV_FRP_PORT_MAX=13100

# frpc process manager (started by API)
NONAV_FRP_CLIENT_BIN=/opt/nonav/frp/frpc
NONAV_FRP_SERVER_ADDR=<PUBLIC_SERVER_IP_OR_DOMAIN>
NONAV_FRP_SERVER_PORT=7000
NONAV_FRP_AUTH_TOKEN=<CHANGE_ME>
NONAV_FRP_EXPOSE_API=true
NONAV_FRP_API_REMOTE_PORT=18081
NONAV_FRP_RECOVER_ON_START=false
